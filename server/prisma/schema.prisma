// Приведено в соответствие с текущим API:
// - id и projectId → Int (auto-increment)
// - поля проекта: title, description
// - поля задачи: title, description?, status?, priority?
// - связь Project → Task
// === TF CLEANUP END (Copilot) ===

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  tasks       Task[]
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      Status   @default(todo)
   priority    Priority  @default(medium)
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id])
  createdAt   DateTime @default(now())
}

enum Status {
  todo
  in_progress
  done
}

enum Priority {
  low
  medium
  high
}

